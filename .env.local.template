# Copy this file to .env.local and fill values before launching ERP modules.
# Windows PowerShell example:
# Copy-Item .env.local.template .env.local

# -----------------------------
# Finance module (Supabase REST)
# -----------------------------
# Either set SUPABASE_URL (project URL), or set SUPABASE_REST_URL directly.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_REST_URL=https://YOUR_PROJECT_REF.supabase.co/rest/v1

# Set one of these keys (service role preferred for backend/admin operations).
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# SUPABASE_API_KEY=YOUR_API_KEY
# SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ---------------------------------
# Inventory module (Supabase REST)
# ---------------------------------
# Inventory now uses Supabase REST API via SUPABASE_URL and API key.
# Reuses the same values configured above for Finance.
#
# If you use separate keys per module, keep Finance and Inventory in sync:
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ---------------------------
# Sales module (Supabase REST)
# ---------------------------
# Sales now uses Supabase REST API with API key, same as Finance/Inventory.
# Ensure your Supabase project has these tables:
# - users (for login)
# - orders (for sales records)
# The Sales module reuses SUPABASE_URL + key values above.

# -------------------------
# HRM module (Supabase REST)
# -------------------------
# HRM now uses Supabase REST API with API key.
# Ensure table exists in Supabase:
# - hrm_employees
# The HRM module reuses SUPABASE_URL + key values above.
